# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

# Anthropic — Claude Opus 4.7
# Agent SDK default mode + raw SDK fallback both consume this key.
ANTHROPIC_API_KEY=

# GitHub — for opening real PRs against danielmedinac22/flarebill-*
# Required scope: `repo`
# If you use `gh` CLI (recommended), you can extract with: `gh auth token`
GITHUB_TOKEN=
